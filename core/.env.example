# OpenConnect Environment Configuration
# DO NOT COMMIT ACTUAL .env FILE TO VERSION CONTROL

# Device Identity
DEVICE_PRIVATE_KEY=
DEVICE_PUBLIC_KEY=
DEVICE_ID=

# Network Configuration
MODE=LOCAL  # Options: LOCAL, RELAY, HYBRID
VPS_RELAY_URL=wss://api.yourdomain.com/ws/connect
VPN_IP_ADDRESS=

# Payment & Tier Verification (Server-Side)
# These keys are only used by the VPS backend, not local clients.
RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=
LICENSE_VERIFICATION_URL=https://api.yourdomain.com/v1/verify
