# OpenConnect Environment Configuration
# NEVER COMMIT THIS FILE TO GITHUB

# Django Secrets
DJANGO_SECRET_KEY=replace_this_with_a_long_secure_random_string_for_production
DJANGO_DEBUG=True

# Database Configuration
POSTGRES_DB=openconnect
POSTGRES_USER=oc_admin
POSTGRES_PASSWORD=oc_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# WireGuard Configuration
WG_SERVER_PUBLIC_KEY=your_actual_vps_wireguard_public_key_here
WG_SERVER_ENDPOINT=12.34.56.78:51820

# Razorpay Keys (Test/Live)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
RAZORPAY_WEBHOOK_SECRET=your_custom_webhook_secret_string
